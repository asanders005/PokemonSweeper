<Window x:Class="PokemonSweeper.PokemonDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PokemonSweeper"
        mc:Ignorable="d"
        Loaded="WindowLoaded"
        Title="Pokemon Details" Width="500" Height="400">
    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" HorizontalAlignment="Left" Margin="165 0 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Name="PokemonNameEntry" Visibility="Hidden" HorizontalContentAlignment="Center" Text="Name" FontSize="40" Height="80" VerticalContentAlignment="Bottom" HorizontalAlignment="Center"/>
            <Label Grid.Column="0" Name="PokemonName" Visibility="Visible" HorizontalContentAlignment="Center" Content="Name" FontSize="40" Height="80" VerticalContentAlignment="Bottom" HorizontalAlignment="Center"/>
            <Button Grid.Column="1" Name="EditPokemonName" Click="EditButton" Content="Edit" Padding="5" FontSize="20" Margin="20 0 0 10" VerticalAlignment="Bottom"/>
        </Grid>
        <DockPanel Grid.Row="1">
            <Image Name="PokemonImage" RenderOptions.BitmapScalingMode="NearestNeighbor" VerticalAlignment="Center" Width="150" Source="images/pokeball.png" Margin="10 0 10 0" DockPanel.Dock="Left"/>
            <Label Name="PokemonLevel" Content="Level 1" FontSize="20" VerticalContentAlignment="Top" DockPanel.Dock="Top"/>
            <Label Name="PokemonType" Content="Type" FontSize="20" VerticalContentAlignment="Top" DockPanel.Dock="Top"/>
            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Name="PokemonHP" Content="HP: 100" FontSize="20" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Top"/>
                <Label Grid.Row="1" Grid.Column="0" Name="PokemonAttack" Content="Attack: 100" FontSize="20" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Top"/>
                <Label Grid.Row="2" Grid.Column="0" Name="PokemonDefense" Content="Attack: 100" FontSize="20" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Top"/>
                <Label Grid.Row="0" Grid.Column="1" Name="PokemonSpAttack" Content="Sp. Attack: 100" FontSize="20" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Top"/>
                <Label Grid.Row="1" Grid.Column="1" Name="PokemonSpDefense" Content="Sp. Defense: 100" FontSize="20" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Top"/>
                <Label Grid.Row="2" Grid.Column="1" Name="PokemonSpeed" Content="Attack: 100" FontSize="20" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Top"/>
            </Grid>
        </DockPanel>
        <Button Grid.Row="2" Name="BackButton" Click="BackClick" Content="Back" FontSize="20" Width="100" Height="30" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10 10 10 10"/>
    </Grid>
</Window>
