<Window x:Class="PokemonSweeper.Game.Messages.BattleMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Window1" Height="245" Width="434">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="30"></RowDefinition>
			<RowDefinition Height="30"></RowDefinition>
			<RowDefinition Height="120"></RowDefinition>
			<RowDefinition></RowDefinition>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>

		</Grid.ColumnDefinitions>
		<TextBlock Name="encounter" Grid.Column="0" Grid.Row="0" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">A Wild Pokemon Appeared!</TextBlock>
		<TextBlock Name="battle" Grid.Column="0" Grid.Row="1" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">Your team defeated the Pokemon!/n Pokemon fainted during battle:</TextBlock>
		<ListBox Grid.Column="0" Grid.Row="2" Name="ListBoxPokemon" DockPanel.Dock="Top" Height="100" Margin="10">
			<ListBox.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Horizontal"></StackPanel>
				</ItemsPanelTemplate>
			</ListBox.ItemsPanel>
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border BorderBrush="Black" BorderThickness="1" Width="70">
						<StackPanel>
							<Image Source="{Binding Path=SpriteUrl}" Stretch="Fill" Height="50" Width="50"></Image>
							<TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding Path=Pokemon.Name}"></TextBlock>
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<Button Name="Next" Grid.Column="0" Grid.Row="2" Width="75" VerticalAlignment="Stretch"  HorizontalAlignment="Right" Click="Menu_Click">Continue >></Button>

	</Grid>
</Window>
